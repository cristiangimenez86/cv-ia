ASPNETCORE_URLS=http://localhost:8080
SERVICE_NAME=cv-ia-backend

# Optional: override OpenAiChat section (primary source is appsettings*.json).
# OpenAiChat__ApiKey=
# Required for sk-proj-... (project-scoped) keys — without it OpenAI returns 401:
# OpenAiChat__OpenAiProjectId=proj_xxxxxxxx
# Optional if your org requires it:
# OpenAiChat__OpenAiOrganizationId=org_xxxxxxxx
# OpenAiChat__UseStubChatService=false
# OpenAiChat__Model=gpt-4o-mini
# OpenAiChat__Temperature=0.3
# OpenAiChat__MaxTokens=512
