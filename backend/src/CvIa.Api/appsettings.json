{
  "SERVICE_NAME": "cv-ia-backend",
  "OpenAiChat": {
    "ApiKey": "",
    "OpenAiProjectId": "",
    "OpenAiOrganizationId": "",
    "Model": "gpt-4o-mini",
    "BaseUrl": "https://api.openai.com/v1",
    "HttpTimeoutSeconds": 60,
    "Temperature": 0.3,
    "MaxTokens": 512,
    "MaxMessagesInWindow": 20,
    "UseStubChatService": true
  },
  "CvApi": {
    "PdfAssetPath": "Assets/Cv/cv.pdf",
    "MarkdownContentRoot": "../../../content",
    "MaxCvMarkdownChars": 120000,
    "RateLimiting": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
