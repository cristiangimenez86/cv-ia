{
  "SERVICE_NAME": "cv-ia-backend",
  "ConnectionStrings": {
    "Rag": ""
  },
  "OpenAiChat": {
    "ApiKey": "",
    "OpenAiProjectId": "",
    "OpenAiOrganizationId": "",
    "Model": "gpt-4o-mini",
    "BaseUrl": "https://api.openai.com/v1",
    "HttpTimeoutSeconds": 60,
    "Temperature": 0.5,
    "MaxTokens": 512,
    "MaxMessagesInWindow": 20,
    "UseStubChatService": true
  },
  "Rag": {
    "Enabled": false,
    "EmbeddingModel": "text-embedding-3-small",
    "EmbeddingDimensions": 1536,
    "TopK": 8,
    "MaxRetrievedContextTokens": 4000,
    "IngestionApiKey": "",
    "Sources": [
      {
        "Id": "cv",
        "Type": "cv-sections",
        "ContentRoot": "../../../content"
      }
    ]
  },
  "CvApi": {
    "PdfAssetPath": "Assets/Cv/cv.en.pdf",
    "PdfAssetPaths": {
      "en": "Assets/Cv/cv.en.pdf",
      "es": "Assets/Cv/cv.es.pdf"
    },
    "MarkdownContentRoot": "../../../content",
    "MaxCvMarkdownChars": 120000,
    "RateLimiting": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
