# Leave empty: browser calls same-origin /api/* and /health; Route Handlers proxy to the backend.
# Optional direct API URL: NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
NEXT_PUBLIC_API_BASE_URL=
# When using direct API URL + ApiAccess:RequireToken on the backend, token is visible in the client bundle:
# NEXT_PUBLIC_API_ACCESS_TOKEN=
# Server-only (proxy target). Default http://127.0.0.1:8080
# BACKEND_INTERNAL_URL=http://127.0.0.1:8080
# Server-only bearer for /api/* proxy (must match ApiAccess:Token on .NET when RequireToken is true)
# BACKEND_API_ACCESS_TOKEN=
